# Normalize all text files to LF in the repository (avoids CRLF churn on Windows).
* text=auto eol=lf

# Explicit LF for files that MUST stay LF (shell scripts break with CRLF).
*.sh    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.json  text eol=lf

# Treat common binaries as binary (no EOL conversion).
*.png binary
*.jpg binary
*.gif binary
*.ico binary
